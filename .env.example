# Twelfth Night — Environment Configuration
# Copy this file to .env and fill in your values.

# SiliconFlow API key for LLM-powered response generation
# Obtain a free key at: https://siliconflow.cn
SILICONFLOW_API_KEY=your_api_key_here

# Serial port for M5StickC Plus hardware companion (optional)
# Auto-detected on most systems; set manually if needed
# Windows example: COM3
# macOS example: /dev/cu.usbserial-*
# Linux example: /dev/ttyUSB0
SERIAL_PORT=your_serial_port_here
